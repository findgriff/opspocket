# forms-api overlay build-time values.
# Copy to `.env` and fill with real values. DO NOT COMMIT .env (gitignored).
# These values get baked into the image at build time so herokuish's
# /app/.profile.d/01-app-env.sh sources them correctly at runtime.

ALLOWED_ORIGINS=https://darleyabbeyfc.com,https://www.darleyabbeyfc.com
DATABASE_URL=mysql://root:CHANGEME@forms-db-mariadb:3306/forms_db
FORM_API_KEY=CHANGEME
NOTIFY_FROM=info@darleyabbeyfc.com
NOTIFY_TO=info@darleyabbeyfc.com
SMTP_HOST=mail.privateemail.com
SMTP_PASS=CHANGEME
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@darleyabbeyfc.com
