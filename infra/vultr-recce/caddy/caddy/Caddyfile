# ── OpsPocket landing site ────────────────────────────────────────────────
# Serves both :80 and :443. Caddy auto-issues an internal self-signed cert
# for :443, which Cloudflare accepts in "Full" (not "Full Strict") mode.
# The CF edge terminates public TLS with its own cert, so browsers see a
# trusted cert end-to-end.
opspocket.com, www.opspocket.com {
    tls internal

    root * /var/www/opspocket
    encode gzip zstd

    try_files {path} {path}.html

    file_server {
        hide .*
    }

    handle_errors {
        rewrite * /404.html
        file_server
    }

    @static path /_next/static/*
    header @static Cache-Control "public, max-age=31536000, immutable"

    @html path *.html /
    header @html Cache-Control "public, max-age=300, must-revalidate"
}
