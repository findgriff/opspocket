# /usr/lib/systemd/system/code-server@.service
[Unit]
Description=code-server
After=network.target

[Service]
Type=exec
ExecStart=/usr/bin/code-server
Restart=always
User=%i

[Install]
WantedBy=default.target

# /etc/systemd/system/code-server@openclaw.service.d/override.conf
[Service]
Environment=CS_DISABLE_GETTING_STARTED_OVERRIDE=1
ExecStart=
ExecStart=/usr/bin/code-server --bind-addr 127.0.0.1:6969
